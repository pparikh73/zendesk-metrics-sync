        "jsCode": "const embeddings = $json.data || [];\nconst articles = $('Code - Filter + Clean Articles').first().json.articles;\n\nreturn embeddings.map((e, i) => {\n  const article = articles[i];\n  if (!article) return null;\n  return {\n    json: {\n      article_id: article.article_id,\n      title: (article.title || '').replace(/'/g, \"''\"),\n      body_text: (article.body_text || '').replace(/'/g, \"''\"),\n      section_id: article.section_id || null,\n      url: article.url,\n      outdated: article.outdated || false,\n      draft: article.draft || false,\n      updated_at: article.updated_at,\n      embedding: JSON.stringify(e.embedding),\n      embedded_at: new Date().toISOString(),\n      source: article.source\n    }\n  };\n}).filter(Boolean);\n"
      },
