    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO kb_coverage_results (ticket_id, coverage, top_similarity, top_article_id, top_article_title, summary)\nVALUES (\n  {{ $json.ticket_id }},\n  '{{ $json.coverage }}',\n  {{ $json.articles.length > 0 ? $json.articles[0].similarity : 'NULL' }},\n  {{ $json.articles.length > 0 ? $json.articles[0].article_id : 'NULL' }},\n  '{{ $json.articles.length > 0 ? $json.articles[0].title.replace(/'/g, \"''\") : '' }}',\n  '{{ $json.issue_summary ? $json.issue_summary.replace(/'/g, \"''\") : '' }}'\n)\nON CONFLICT (ticket_id) DO UPDATE SET\n  coverage = EXCLUDED.coverage,\n  top_similarity = EXCLUDED.top_similarity,\n  top_article_id = EXCLUDED.top_article_id,\n  top_article_title = EXCLUDED.top_article_title,\n  summary = EXCLUDED.summary,\n  scanned_at = NOW();\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
