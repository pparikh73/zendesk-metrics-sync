    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ticket = $('Code - Prepare Ticket Text1').item.json;\nconst summary = $('Code - Extract Summary1').item.json.summary;\nconst articles = $json.articles || [];\n\nconst MIN_SIMILARITY = 0.5;\nconst filtered = articles.filter(r => r.similarity >= MIN_SIMILARITY);\nconst bestMatch = filtered.length > 0 ? filtered[0] : null;\n\nlet coverage;\nif (bestMatch && bestMatch.similarity >= 0.75) {\n  coverage = 'covered';\n} else if (bestMatch && bestMatch.similarity >= 0.60) {\n  coverage = 'partial';\n} else {\n  coverage = 'none';\n}\n\nreturn {\n  json: {\n    ticket_id: ticket.ticket_id,\n    issue_summary: summary,\n    coverage: coverage,\n    articles: filtered\n  }\n};\n"
      },
