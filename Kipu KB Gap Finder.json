        "query": "INSERT INTO kb_article_embeddings (\n  article_id, title, body_text, section_id, url,\n  outdated, draft, embedding, embedded_at, updated_at, source\n) VALUES (\n  {{ $json.article_id }},\n  '{{ $json.title.replace(/'/g, \"''\") }}',\n  '{{ $json.body_text.replace(/'/g, \"''\") }}',\n  {{ $json.section_id }},\n  '{{ $json.url }}',\n  {{ $json.outdated }},\n  {{ $json.draft }},\n  '{{ $json.embedding }}'::vector,\n  NOW(),\n  '{{ $json.updated_at }}',\n  '{{ $json.source }}'\n)\nON CONFLICT (article_id, source) DO UPDATE SET\n  title = EXCLUDED.title,\n  body_text = EXCLUDED.body_text,\n  embedding = EXCLUDED.embedding,\n  outdated = EXCLUDED.outdated,\n  draft = EXCLUDED.draft,\n  embedded_at = NOW(),\n  updated_at = EXCLUDED.updated_at;\n",
