      "id": "b74d0069-1399-4c24-aead-4c32e77723f6",
      "name": "Code - Extract Summary"
    },
    {
      "parameters": {
        "jsCode": "const results = $input.all().map(i => i.json);\nconst ticket = $('Code - Prepare Ticket Text').first().json;\nconst summary = $('Code - Extract Summary').first().json.summary;\n\nconst MIN_SIMILARITY = 0.5;\nconst filtered = results.filter(r => r.similarity >= MIN_SIMILARITY);\n\nconst bestMatch = filtered.length > 0 ? filtered[0] : null;\n\nlet coverage;\nif (bestMatch && bestMatch.similarity >= 0.75) {\n  coverage = 'covered';\n} else if (bestMatch && bestMatch.similarity >= 0.60) {\n  coverage = 'partial';\n} else {\n  coverage = 'none';\n}\n\nreturn [{\n  json: {\n    ticket_id: ticket.ticket_id,\n    status: ticket.status,\n    issue_summary: summary,\n    coverage: coverage,\n    coverage_label: coverage === 'covered'\n      ? 'A relevant article exists for this topic'\n      : coverage === 'partial'\n      ? 'Partial match — review these articles'\n      : 'No article found for this topic',\n    articles: filtered.map(r => ({\n      article_id: r.article_id,\n      title: r.title,\n      url: r.url,\n      outdated: r.outdated,\n      similarity: r.similarity,\n      match_quality: r.similarity >= 0.75 ? 'strong' : 'possible'\n    }))\n  }\n}];\n"
      },
