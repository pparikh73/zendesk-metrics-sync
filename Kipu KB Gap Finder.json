      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\nconst baseUrl = data.base_url || 'https://kipuhealth.zendesk.com';\nconst source = data.source || 'emr';\n\nconst allArticles = [];\nfor (const item of $input.all()) {\n  const articles = item.json.articles || [];\n  allArticles.push(...articles);\n}\n\nconst cleaned = allArticles.filter(a => !a.draft).map(a => {\n  const bodyText = (a.body || '')\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .slice(0, 8000);\n\n  return {\n    article_id: a.id,\n    title: a.title,\n    body_text: bodyText,\n    section_id: a.section_id,\n    url: `${baseUrl}/hc/en-us/articles/${a.id}`,\n    outdated: a.outdated || false,\n    draft: a.draft || false,\n    updated_at: a.updated_at,\n    source: source,\n    embed_input: `${a.title}\\n\\n${bodyText}`\n  };\n});\n\nreturn [{ json: {\n  inputs: cleaned.map(a => a.embed_input),\n  articles: cleaned\n}}];\n"
      },
