        "query": "SELECT \n  json_agg(\n    json_build_object(\n      'article_id', article_id,\n      'title', title,\n      'url', url,\n      'outdated', outdated,\n      'similarity', ROUND((1 - (embedding <=> ('[' || '{{ $json.data[0].embedding }}' || ']')::vector))::numeric, 3)\n    ) ORDER BY embedding <=> ('[' || '{{ $json.data[0].embedding }}' || ']')::vector\n  ) as articles\nFROM (\n  SELECT article_id, title, url, outdated, embedding\n  FROM kb_article_embeddings\n  WHERE outdated = false\n  ORDER BY embedding <=> ('[' || '{{ $json.data[0].embedding }}' || ']')::vector\n  LIMIT 5\n) sub;\n",
