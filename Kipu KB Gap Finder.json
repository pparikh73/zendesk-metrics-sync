    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ticket = $('HTTP - Fetch Ticket').first().json.ticket;\nconst comments = $('HTTP - Fetch Ticket Comments').first().json.comments || [];\n\nif (!ticket) throw new Error('Ticket not found');\n\nconst subject = ticket.subject || '';\n\n// Get first 3 public comments (actual conversation, not just description)\nconst publicComments = comments\n  .filter(c => c.public)\n  .slice(0, 3)\n  .map(c => c.body || '')\n  .join('\\n\\n---\\n\\n')\n  .slice(0, 2000);\n\nconst userPrompt = `Subject: ${subject}\\n\\nConversation:\\n${publicComments || 'No comments available'}`;\n\nreturn {\n  json: {\n    ticket_id: ticket.id,\n    status: ticket.status,\n    form_id: ticket.ticket_form_id,\n    system_prompt: `You are a support ticket analyzer. Extract the core support question from the ticket below. Remove all personally identifiable information (names, emails, phone numbers, account numbers, dates of birth, facility names). Return only a 2-3 sentence plain English summary of the technical or functional issue being reported. No PHI, no metadata, just the question.`,\n    user_prompt: userPrompt\n  }\n};\n"
      },
