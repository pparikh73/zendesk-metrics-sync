        "jsCode": "const summary = $json.output_text || $json.text || $json.response || '';\nconst ticket = $('Code - Prepare Ticket Text1').item.json;\n\nreturn {\n  json: {\n    ticket_id: ticket.ticket_id,\n    status: ticket.status,\n    form_id: ticket.form_id,\n    summary: summary,\n    embed_input: summary\n  }\n};\n"
