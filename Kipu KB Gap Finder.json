        "jsCode": "const body = $('Webhook - KB Embed Sync').first().json.body || {};\nconst source = body.source || 'emr';\nconst baseUrl = body.base_url || 'https://kipuhealth.zendesk.com';\n\nconst data = $getWorkflowStaticData('global');\ndata.source = source;\ndata.base_url = baseUrl;\n\nreturn [{\n  json: {\n    url: `${baseUrl}/api/v2/help_center/articles.json?per_page=100&page=1`,\n    source: source,\n    base_url: baseUrl\n  }\n}];\n"
